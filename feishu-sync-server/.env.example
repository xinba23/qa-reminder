# 飞书自建应用（必填）
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# 写入模式二选一：
# 模式1：追加到已有云文档（推荐，一篇长期日志）
FEISHU_DOCUMENT_ID=doxcnxxxxxxxxxxxxxxxx

# 模式2：每次同步创建新文档（需文件夹 token）
# FEISHU_FOLDER_TOKEN=fldcnxxxxxxxx

# 工作台调用本服务时的鉴权密钥（建议设置，填到工作台「API Key」）
API_KEY=your-random-secret-key

# 服务端口
PORT=8787
